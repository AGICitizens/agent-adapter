{
  "name": "@agent-adapter/core",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "import": "./dist/proxy/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./payments": {
      "types": "./dist/payments/index.d.ts",
      "import": "./dist/payments/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities/registry.d.ts",
      "import": "./dist/capabilities/registry.js"
    },
    "./jobs": {
      "types": "./dist/jobs/index.d.ts",
